        <Member Name="PhoneType" Caption="Typ telefonu" />
      </OwnMembers>
    </Class>
  </BOModel>
  <Localization>
    <LocalizationGroup Name="Paycheck" IsNewNode="True">
      <LocalizationItem Name="ChartLabel" Value="Miesięczny harmonogram wynagrodzeń" IsNewNode="True" />
    </LocalizationGroup>
  </Localization>
  <Views>
    <ListView Id="Employee_ListView" Caption="Pracownicy" />
    <ListView Id="Department_ListView" Caption="Działy" />
    <ListView Id="DemoTask_ListView" Caption="Zadania" />
    <ListView Id="Note_ListView" Caption="Notatki" />
    <ListView Id="Paycheck_ListView" Caption="Wypłaty" />
    <ListView Id="Paycheck_ListView_Varied" Caption="Wypłaty">
      <Variants>
        <Variant Id="Default" Caption="Widok siatki" IsNewNode="True" />
        <Variant Id="Chart" Caption="Widok wykresu" IsNewNode="True" />
      </Variants>
    </ListView>
  </Views>
</Application>
