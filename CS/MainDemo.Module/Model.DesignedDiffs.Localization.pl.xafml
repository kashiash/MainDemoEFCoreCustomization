<?xml version="1.0" encoding="utf-8"?>
<Application Title="MainDemo - Outlook w 60 minut!">
  <ActionDesign>
    <Actions>
      <Action Id="Cancel" Caption="Anuluj" ToolTip="Anuluj" />
      <Action Id="ClearTasksAction" Caption="Wyczyść zadania" ToolTip="Wyczyść zadania" />
      <Action Id="Delete" Caption="Usuń" ConfirmationMessage="Czy na pewno chcesz usunąć {0} rekordów?" ToolTip="Usuń" />
      <Action Id="DemoTask.Postpone" Caption="Odłóż" ToolTip="Odłóż" />
      <Action Id="FullTextSearch" Caption="Wyszukiwanie pełnotekstowe" />
      <Action Id="Link" Caption="Powiąż" ToolTip="Powiąż" />
      <Action Id="NavigateBack" Caption="Wstecz" ToolTip="Wstecz" />
      <Action Id="NavigateForward" Caption="Dalej" ToolTip="Dalej" />
      <Action Id="New" Caption="Nowy" ToolTip="Nowy" />
      <Action Id="NextObject" Caption="Następny" ToolTip="Następny" />
      <Action Id="PreviousObject" Caption="Poprzedni" ToolTip="Poprzedni" />
      <Action Id="Refresh" Caption="Odśwież" ToolTip="Odśwież" />
      <Action Id="Save" Caption="Zapisz" ToolTip="Zapisz" />
      <Action Id="SaveAndClose" Caption="Zapisz i zamknij" ToolTip="Zapisz i zamknij" />
      <Action Id="SaveAndNew" Caption="Zapisz i nowy" ToolTip="Zapisz i nowy" />
      <Action Id="SetTaskAction" Caption="Ustaw zadanie..." ToolTip="Ustaw zadanie..." />
      <Action Id="ShowAllContexts" Caption="Waliduj" ToolTip="Waliduj zaznaczone obiekty we wszystkich kontekstach" />
      <Action Id="ShowNavigationItem" Caption="Otwórz moduł" />
      <Action Id="ShowNotesAction" Caption="Pokaż notatki" />
      <Action Id="Unlink" Caption="Usuń powiązanie" ToolTip="Usuń powiązanie" ConfirmationMessage="Powiązania dla {0} rekordów zostaną usunięte. Czy chcesz kontynuować?" />
    </Actions>
    <DisableReasons>
      <Reason Id="ByContext_RequireMultipleObjects" Caption="Musi być zaznaczony co najmniej jeden obiekt" />
      <Reason Id="ByContext_RequireSingleObject" Caption="Musi być zaznaczony jeden obiekt" />
      <Reason Id="Security" Caption="Brak uprawnień" />
    </DisableReasons>
  </ActionDesign>
  <BOModel>
    <Class Name="DevExpress.Persistent.BaseImpl.EF.PermissionPolicy.PermissionPolicyRole" Caption="Rola">
      <OwnMembers>
        <Member Name="Users" Caption="Użytkownicy" />
      </OwnMembers>
    </Class>
    <Class Name="DevExpress.Persistent.BaseImpl.EF.PermissionPolicy.PermissionPolicyUser" Caption="Użytkownik">
      <OwnMembers>
        <Member Name="ChangePasswordOnFirstLogon" Caption="Zmień hasło przy pierwszym logowaniu" />
        <Member Name="IsActive" Caption="Aktywny" />
        <Member Name="Roles" Caption="Role" />
        <Member Name="UserName" Caption="Nazwa użytkownika" />
      </OwnMembers>
    </Class>
    <Class Name="MainDemo.Module.BusinessObjects.Address" Caption="Adres">
      <OwnMembers>
        <Member Name="City" Caption="Miasto" />
