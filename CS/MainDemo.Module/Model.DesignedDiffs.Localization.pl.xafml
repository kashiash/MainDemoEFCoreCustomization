        <Member Name="StateProvince" Caption="Województwo / region" />
        <Member Name="Street" Caption="Ulica" />
        <Member Name="ZipPostal" Caption="Kod pocztowy" />
      </OwnMembers>
    </Class>
    <Class Name="MainDemo.Module.BusinessObjects.Country" Caption="Kraj">
      <OwnMembers>
        <Member Name="PhoneCode" Caption="Kierunkowy" />
      </OwnMembers>
    </Class>
    <Class Name="MainDemo.Module.BusinessObjects.DemoTask" Caption="Zadanie">
