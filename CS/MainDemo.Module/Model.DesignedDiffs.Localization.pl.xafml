        <Member Name="Manager" Caption="Przełożony" />
        <Member Name="MiddleName" Caption="Drugie imię" />
        <Member Name="NickName" Caption="Pseudonim" />
        <Member Name="Notes" Caption="Notatki" />
        <Member Name="PhoneNumbers" Caption="Numery telefonu" />
        <Member Name="Photo" Caption="Zdjęcie" />
        <Member Name="Position" Caption="Stanowisko" />
        <Member Name="SpouseName" Caption="Imię małżonka" />
        <Member Name="Tasks" Caption="Zadania" />
