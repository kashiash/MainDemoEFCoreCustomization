		<ListView Id="Paycheck_ListView_Chart_PerEmployee" Caption="Payroll" ClassName="MainDemo.Module.BusinessObjects.Paycheck" DataAccessMode="DataView" EditorTypeName="DevExpress.ExpressApp.Blazor.Editors.DxChartListEditor" SettingTypeName="MainDemo.Blazor.Server.Charts.PaycheckChartPerEmployee" IsNewNode="True">
			<Columns>
