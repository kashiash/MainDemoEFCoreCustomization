		</ListView>
		<ListView Id="Paycheck_ListView_Chart" Caption="Payroll" ClassName="MainDemo.Module.BusinessObjects.Paycheck" DataAccessMode="DataView" EditorTypeName="DevExpress.ExpressApp.Blazor.Editors.DxChartListEditor" SettingTypeName="MainDemo.Blazor.Server.Charts.PaycheckChart" IsNewNode="True">
			<Columns>
