			<Layout>
				<LayoutGroup Id="Main">
					<LayoutGroup Id="RootGroup">
						<LayoutGroup Id="ImageGroup">
							<LayoutItem Id="LogonImage" Removed="True" />
						</LayoutGroup>
						<LayoutGroup Id="EditorsGroup">
							<LayoutGroup Id="Text">
								<LayoutItem Id="LogonText" />
